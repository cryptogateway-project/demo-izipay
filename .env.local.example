# --- IziShop — boutique de démonstration (sandbox IzichangePay) ---
# Copiez ce fichier en .env.local et renseignez vos valeurs.

# Clé API SECRÈTE, créée au dashboard (Intégration → Clés API).
# Préfixe sk_test_ ou sk_live_ ; pointez sur le sandbox via IZIPAY_API_BASE_URL.
IZIPAY_API_KEY=sk_test_<votre-cle-de-test-ici>     # ou sk_live_… (72 car. : sk_<env>_ + 64 hex)

# Base URL de l'API (sandbox par défaut).
IZIPAY_API_BASE_URL=https://mon site

# Origine qui sert le widget de paiement (embed.js + modale). DOIT correspondre à
# l'origine du paymentLink renvoyé par l'API. Exposée au navigateur (préfixe
# NEXT_PUBLIC_) car embed.js est chargé en amont pour rendre le bouton officiel
# IziPay.Button au montage du panier.
#   - Sandbox : https://checkout.sandbox-pay.izichange.com
#   - Prod    : https://checkout.pay.izichange.com
#   - Local   : http://localhost:7011
NEXT_PUBLIC_IZIPAY_WIDGET_ORIGIN=https://checkout.sandbox-pay.izichange.com

# Secret de l'endpoint webhook créé au dashboard (Intégration → Webhooks).
# Commence par whsec_. Sert à vérifier la signature des webhooks reçus sur /webhook.
IZIPAY_WEBHOOK_SECRET=whsec_<votre-secret-webhook-ici>

# Base des returnUrl (le navigateur du client y revient après le checkout).
SITE_URL=http://monsite.com

# Cryptos acceptées au checkout — liste d'assetCodes ACTIVÉS sur votre compte marchand,
# séparés par des virgules. Indispensable si la clé n'a pas le scope merchants:read
# (l'app ne peut alors pas les détecter automatiquement).
# Exemple pour un compte où seul TRX est actif :
IZIPAY_ACCEPTED_COINS=TRX

# (optionnel) Cible du script de test de webhook.
# WEBHOOK_URL=http:///monsite.com
